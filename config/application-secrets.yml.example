# =============================================================================
# Скопируйте в application-secrets.yml (рядом с этим файлом):
#   copy config\application-secrets.yml.example config\application-secrets.yml
# Файл application-secrets.yml в .gitignore — не коммитьте секреты.
#
# Этот файл подхватывается через spring.config.import в application.yml
# (рабочий каталог процесса = обычно корень проекта при запуске из IDEA).
# =============================================================================

# --- Webhook HTTP (Authorization: Bearer <token>) ---
webhook:
  # Секрет для POST /webhook. Либо литерал, либо ссылка на переменную окружения:
  token: "CHANGE_ME_WEBHOOK_SECRET"
  # token: ${WEBHOOK_TOKEN:}
  # Для нагрузочного теста подряд с одним и тем же телом — отключите дедупликацию:
  # deduplication-enabled: false
  # deduplication-window-seconds: 60

# --- Telegram ---
telegram:
  # Токен бота от @BotFather
  bot-token: "000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA"
  # bot-token: ${TELEGRAM_BOT_TOKEN:}

  # Основной получатель (личка, группа или канал)
  chat-id: "123456789"
  # chat-id: ${TELEGRAM_CHAT_ID:}

  # Дополнительные chat_id (опционально). Итог = chat-id + список, без дублей.
  notify-chat-ids:
    - "111111111"
    - "222222222"
    - "-1003333333333"

  # Тестовый режим: опрос getUpdates + рассылка накопленным chat_id (см. README).
  # На production держите false.
  test-mode: false
  test-collect-interval-ms: 6000

# -----------------------------------------------------------------------------
# Минимальный рабочий вариант (без notify и без test-mode):
#
# webhook:
#   token: "my-secret"
# telegram:
#   bot-token: "123:ABC..."
#   chat-id: "987654321"
#
# Если всё задано через env (WEBHOOK_TOKEN, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID),
# в этом файле можно оставить только notify-chat-ids / test-mode.
# -----------------------------------------------------------------------------
